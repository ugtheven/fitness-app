{
  "expo": {
    "name": "fitness-app",
    "slug": "fitness-app",
    "version": "0.1.0",
    "scheme": "fitness-app",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000"
      },
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize"
    },
    "plugins": [
      "expo-sqlite",
      "expo-router",
      "@react-native-community/datetimepicker"
    ]
  }
}
